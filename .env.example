# ⚡ APEX ORACLE — Environment Variables
# ─────────────────────────────────────────────────
# INSTRUCTIONS:
# 1. Copy this file and rename it to .env
# 2. Fill in ALL values below
# 3. NEVER commit .env to GitHub (already in .gitignore)
# 4. On Render.com add these same variables in dashboard
# ─────────────────────────────────────────────────

# ─── IQ OPTION CREDENTIALS ───────────────────────
IQ_OPTION_EMAIL=your_email@gmail.com
IQ_OPTION_PASSWORD=your_password_here

# ─── TRADING MODE ────────────────────────────────
# Options: PRACTICE (demo) or REAL (live)
# ALWAYS start with PRACTICE!
TRADING_MODE=PRACTICE

# ─── GROQ AI (FREE) ──────────────────────────────
# Get free key at: console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── TELEGRAM BOT ────────────────────────────────
# Create bot via @BotFather on Telegram
# Get chat ID via @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── SUPABASE DATABASE (FREE) ────────────────────
# Create free project at: supabase.com
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ─── RISK MANAGEMENT ─────────────────────────────
# Percentage of balance per trade (recommended: 1-2)
STAKE_PERCENT=1.5
# Maximum trades per day
MAX_DAILY_TRADES=15
# Maximum consecutive losses before pause
MAX_CONSECUTIVE_LOSSES=3
# Daily loss limit percentage (bot shuts down after this)
DAILY_LOSS_LIMIT=5
# Minimum confidence score to execute trade (75-90)
MIN_CONFIDENCE=75

# ─── GOOGLE DRIVE BACKUP (FREE) ──────────────────
# Optional: For weekly database backups
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ─── APP SETTINGS ────────────────────────────────
# Port for keep-alive server (Render uses 10000)
PORT=10000
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Bot timezone
TIMEZONE=Africa/Lagos
